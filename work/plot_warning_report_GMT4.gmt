# location quality results grid
RUN_NAME="epicenter.diff"
TITLE="EpictrConv_(km)"
LONG_TITLE=${TITLE}
#X_POS= - (2.5+${GRID_WIDTH}+0.58)
#@X_POS=-13.06
X_POS=-11.8
#@Y_POS=2.8
Y_POS=2.1375
