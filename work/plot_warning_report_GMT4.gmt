RUN_NAME="t50"

# maps


#echo "DEBUG: plot_warning_report_GMT4.gmt: dt=${SECONDS}: TP 10"
# global map
#X_POS=-29.75
X_POS=-30.25
Y_POS=-15.3
R_VAL=-Rd
J_VAL=-JN150/18c
B_VAL=-B30g30/30g30WEnS
N_VAL=YES
R_VAL_Y=-0.25/25.75
R_VAL_Y_SYM=0.0/25.5
AUTO_CENTER_MAP=NO
LAT_CENT=XXX
SINGLE_EVENT_PLOT_INDEX=NO	# must use NO to plot all events
./plot_warning_map_GMT4.gmt ${SAVE_DIR} ${ROOT_OUT_PATH} ${INSTANCE_PATH_NAME} ${INSTANCE_NAME} ${RUN_NAME} ${X_POS} ${Y_POS} ${R_VAL} ${J_VAL} \
	${B_VAL} ${N_VAL} ${AUTO_CENTER_MAP} ${LAT_CENT} ${SINGLE_EVENT_PLOT_INDEX} ${PLOT_MAP_MECHANISM_TYPE} ${PS_NAME}

#echo "DEBUG: plot_warning_report_GMT4.gmt: dt=${SECONDS}: TP 11"
# NOTE: ===========================================================================================
# set GMT projection defaults here for displayed regional map when no hypocenters located, 
#   or for fixed regional map if you set AUTO_CENTER_MAP=NO
# R_VAL:
#   AUTO_CENTER_MAP=YES uses a latitude range of 70deg and longitude range of 120deg
#     with AUTO_CENTER_MAP=NO, use this range or same ratio of lat/lon, or slightly larger ratio
#     in order to leave sufficient white space above for the hypocenter list
# J_VAL:
#   use -JQ, then the mean of your longitude range, then 37.5 for minimum distortion
#     or the mean of your latitude range, then 13.7c to fit the map width correctly 
#     in the plot graphic
# for more details and options, see: 
#   http://www.soest.hawaii.edu/GMT/gmt/doc/gmt/html/man/psbasemap.html
#   http://www.soest.hawaii.edu/GMT/gmt/doc/gmt/html/GMT_Docs/node108.html
#
# Euro-Med map
R_VAL=-Rg
LON_CENT=12.5
LAT_CENT=45.0
J_VAL=-JG${LON_CENT}/${LAT_CENT}/75000/0/0/0/5/4.7/13.7c
#
# NW US
#R_VAL=-Rg
#LON_CENT=-100.0
#LAT_CENT=40.0
#J_VAL=-JG${LON_CENT}/${LAT_CENT}/75000/0/0/0/5/4.7/13.7c
#
# Chile
#R_VAL=-R-132/-70/-12/5r
#J_VAL=-JQ-72/37.5/13.7c
#
# SW Pacific / Indonesia
#R_VAL=-R75/-45/-165/50r
#J_VAL=-JQ135/0/13.7c
#
# =================================================================================================
#X_POS=+18.9
X_POS=19.1
Y_POS=0.25
B_VAL=-B10g10/10g10nWES
N_VAL=NO
AUTO_CENTER_MAP=YES
SINGLE_EVENT_PLOT_INDEX=NO	# must use NO to plot all events
./plot_warning_map_GMT4.gmt ${SAVE_DIR} ${ROOT_OUT_PATH} ${INSTANCE_PATH_NAME} ${INSTANCE_NAME} ${RUN_NAME} ${X_POS} ${Y_POS} \
${R_VAL} ${J_VAL} ${B_VAL} ${N_VAL} ${AUTO_CENTER_MAP} ${LAT_CENT} ${SINGLE_EVENT_PLOT_INDEX} ${PLOT_MAP_MECHANISM_TYPE} ${PS_NAME}


#echo "DEBUG: plot_warning_report_GMT4.gmt: dt=${SECONDS}: TP 12"
# pick summary text
#1322237820 111 0 0 32 59 13 7 0 0
read PLOT_TIME_MAX NUM_PICK NUM_PICK_NOT_COMPLETED NUM_PICK_CLIPPED NUM_PICK_NON_CONTIGUOUS NUM_PICK_SN_LOW NUM_PICK_SN_BRBV_LOW NUM_PICK_SN_BRBD_LOW \
            NUM_PICK_IN_PREV_CODA NUM_PICK_OK NUM_PICK_ASSOC NUM_EVENT \
		< ${INSTANCE_PATH_NAME}/picks.log
# x,  y,  size,  angle, fontno,  justify,  text
pstext -R0/1/0/1 -JX1 -N -O -K << END >> ${PS_NAME}
-19.5 8.6  8 0 1 BL   ${NUM_PICK} picks, ${NUM_PICK_OK} active,
-19.5 8.25 8 0 1 BL   ${NUM_PICK_ASSOC} associated into
-19.5 7.9  8 0 1 BL   ${NUM_EVENT} events
END


# station summary text
#t50 1.000000 61.016667 2010.01.27-19:42:38 2010.01.27-20:43:39 167 176 1
read DUMMY CRITICAL_VALUE TIME_AXIS_LEN PLOT_START_TIME PLOT_END_TIME TIME_STEP N_ACTIVE N_HAS_BEEN_ACTIVE N_HYPOCENTERS \
		< ${INSTANCE_PATH_NAME}/${RUN_NAME}.csv
# x,  y,  size,  angle, fontno,  justify,  text
pstext -R0/1/0/1 -JX1 -N -O -K << END >> ${PS_NAME}
-0.7 8.80 8 0 1 BR   ${N_HAS_BEEN_ACTIVE} sta, ${N_ACTIVE} w/ latency<${TIME_STEP}s
-0.7 8.50 6 0 1 BR   hypo color @~\256@~ Td\267T50Ex
-0.7 8.25 6 0 1 BR   sta color @~\256@~ Td / T50Ex
-0.7 8.00 6 0 1 BR   (white @~\256@~ latency>${TIME_STEP}s)
END


# program icon
#psimage early-est_395x96.png -C-0.5/0.11/BR -W2.6 -O -K >> ${PS_NAME}

# signature logos
#psimage logo-INGV_64_64.png -Gt255 -C-1.5/0.30/BR -W0.6 -O -K >> ${PS_NAME}
#psimage al_logo_60x96.png -Gt255 -C-3.1/-0.37/BR -W0.4 -O -K >> ${PS_NAME}
psimage al_logo_alomax_scientific_364_100.png -C-0.65/-0.55/BR -W2.9 -O -K >> ${PS_NAME}
psimage banner_INGV_345_90.png -C-0.65/0.15/BR -W2.2 -O -K >> ${PS_NAME}
# close plot (no -K)
psimage NERA_260_64.png -C-0.65/0.95/BR -W0.8 -O >> ${PS_NAME}


#echo "gs -dNOPAUSE -sDEVICE=pdfwrite -sOutputFile=${ROOT_NAME}.pdf ${PS_NAME} -c quit"
gs -dNOPAUSE -sDEVICE=pdfwrite -sOutputFile=${ROOT_NAME}.pdf ${PS_NAME} -c quit

