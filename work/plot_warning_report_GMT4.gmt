#echo "DEBUG: plot_warning_report_GMT4.gmt: dt=${SECONDS}: TP 4"
# alarm results grid
RUN_NAME="alarm"
TITLE="Td\267T50Ex"
LONG_TITLE="${TITLE}_(Tsunami_Potential)"
#X_POS= - (2.5+${GRID_WIDTH}+0.58)
X_POS=-12.36
