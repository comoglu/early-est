${PLOT_START_STOP_TIME} ${PLOT_GRID} ${PLOT_STATION_RESULTS} ${PLOT_SUMMARY_RESULTS} ${HISTOGRAM_BIN_WIDTH} ${PLOT_HISTOGRAM_ONLY} ${PLOT_LAST_LEVEL}
#


# histograms
#echo "DEBUG: plot_warning_report_GMT4.gmt: dt=${SECONDS}: TP 6"
# mb histogram
RUN_NAME="mb"
TITLE="mb(Vmax)"
LONG_TITLE=${TITLE}
#X_POS= - (2.5+${GRID_WIDTH}+0.58)
#X_POS=4.0
X_POS=-7.9
#@Y_POS=-0.4
Y_POS=-1.105
GRID_J_VAL=-Jx${JX}/0.4286
J_VAL_Y_HIST=0.4286
B_VAL_Y_INFO=1.0
GRID_SN_VAL=Sn
R_VAL_Y=2.95/10.15
R_VAL_Y_SYM=3.0/10.1
